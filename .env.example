PORT=3001
# Локально: development. На Render/production: production
NODE_ENV=development

# --- Яндекс.Почта ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@yandex.ru
SMTP_PASS=your-app-password
OWNER_EMAIL=your@yandex.ru

# --- Production (Render Free): Unisender Go через HTTPS ---
# Brevo из РФ часто недоступен. Unisender Go — российский сервис, регистрация с +7.
# Render блокирует SMTP (465/587). Если задан UNISENDER_API_KEY — SMTP не используется.
# 1. https://www.unisender.com → Unisender Go → подтвердите домен или email отправителя
# 2. Настройки → API → скопируйте ключ
# 3. На Render: UNISENDER_API_KEY + MAIL_FROM + OWNER_EMAIL
# UNISENDER_API_KEY=your-unisender-go-api-key
# UNISENDER_API_URL=https://goapi.unisender.ru/ru/transactional/api/v1
# MAIL_FROM=your@yandex.ru

# --- Альтернатива (если доступен Brevo за рубежом) ---
# BREVO_API_KEY=your-brevo-api-key

# --- AI через ProxyAPI (https://proxyapi.ru) ---
# Ключ создаётся в личном кабинете ProxyAPI → «Ключи API»
# НЕ ключ OpenAI напрямую — только ключ ProxyAPI
OPENAI_API_KEY=your-proxyapi-key
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini

# Опционально: HTTP-прокси host:port (если не используете ProxyAPI)
# OPENAI_PROXY=
