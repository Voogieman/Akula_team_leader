PORT=3001
# Локально: development. На Render/production: production
NODE_ENV=development

# --- Unisender Go (https://go2.unisender.ru → Настройки → SMTP) ---
# SMTP_USER — числовой логин из личного кабинета (не email)
# MAIL_FROM — подтверждённый email отправителя
SMTP_HOST=smtp.go2.unisender.ru
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-unisender-login-id
SMTP_PASS=your-unisender-smtp-password
MAIL_FROM=your@email.ru
OWNER_EMAIL=your@email.ru

# --- Render Free: SMTP порт 587 заблокирован → тот же пароль как API-ключ ---
# UNISENDER_API_KEY = SMTP_PASS из настроек Unisender Go
# UNISENDER_API_URL=https://go2.unisender.ru/ru/transactional/api/v1
# UNISENDER_API_KEY=your-unisender-smtp-password

# --- AI через ProxyAPI (https://proxyapi.ru) ---
OPENAI_API_KEY=your-proxyapi-key
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini
