PORT=3001
# Локально: development. На Render/production: production
NODE_ENV=development

# --- Яндекс.Почта ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@yandex.ru
SMTP_PASS=your-app-password
OWNER_EMAIL=your@yandex.ru

# --- Отправка на Render Free (SMTP порты 465/587 заблокированы) ---
# Brevo (https://www.brevo.com): бесплатно 300 писем/день, API через HTTPS
# 1. Зарегистрируйтесь → Senders → подтвердите email отправителя
# 2. SMTP & API → Create API key
# 3. На Render добавьте BREVO_API_KEY (локально можно не задавать — работает Яндекс SMTP)
# BREVO_API_KEY=your-brevo-api-key
# MAIL_FROM=your@yandex.ru

# --- AI через ProxyAPI (https://proxyapi.ru) ---
# Ключ создаётся в личном кабинете ProxyAPI → «Ключи API»
# НЕ ключ OpenAI напрямую — только ключ ProxyAPI
OPENAI_API_KEY=your-proxyapi-key
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini

# Опционально: HTTP-прокси host:port (если не используете ProxyAPI)
# OPENAI_PROXY=
