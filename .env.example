PORT=3001
NODE_ENV=development

# Unisender Go — https://go2.unisender.ru/ru/settings/smtp-configuration
# SMTP_USER — числовой логин (не email). MAIL_FROM — подтверждённый email отправителя.
SMTP_HOST=smtp.go2.unisender.ru
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-unisender-login-id
SMTP_PASS=your-unisender-smtp-password
MAIL_FROM=your@email.ru
OWNER_EMAIL=your@email.ru

# AI через ProxyAPI — https://proxyapi.ru
OPENAI_API_KEY=your-proxyapi-key
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini
