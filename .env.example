PORT=3001
NODE_ENV=development

# Unisender Go — https://go2.unisender.ru
SMTP_HOST=smtp.go2.unisender.ru
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-unisender-login-id
SMTP_PASS=your-unisender-smtp-password

# Sandbox-домен (тест без подтверждения своего домена)
# Получить: Домены отправки → «Получить тестовый домен»
# Получатели (OWNER_EMAIL и email в форме) — только из «Подтверждённые email-адреса»
UNISENDER_SANDBOX_DOMAIN=sandbox-XXXX-XXXX.unigosendbox.com
UNISENDER_SANDBOX_LOCAL=test
MAIL_FROM=test@sandbox-XXXX-XXXX.unigosendbox.com
OWNER_EMAIL=your-verified@email.ru

# AI через ProxyAPI — https://proxyapi.ru
OPENAI_API_KEY=your-proxyapi-key
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini
