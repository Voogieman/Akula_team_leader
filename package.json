{
  "name": "dev-landing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "nest build && nest start --watch",
    "build": "npm run build:server && vite build",
    "build:server": "nest build",
    "start": "node dist/main.js",
    "preview": "vite preview",
    "test": "jest --config server/jest.config.js --testPathPattern=\\.spec\\.ts$",
    "test:ai": "jest --config server/jest.config.js --testPathPattern=ai.service",
    "test:ai:api": "node scripts/test-ai-api.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/throttler": "^6.3.0",
    "https-proxy-agent": "^7.0.6",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "sass": "^1.83.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "vite": "^6.0.6"
  }
}
